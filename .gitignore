# SwiftPM local build products and intermediates
.build/
# Local debug artifacts/logs generated by dev scripts
.debug/
# Release artifacts (zip, cask, checksums)
dist/
# Swift Package Manager local metadata/workspace state
.swiftpm/
# Local Xcode-derived build artifacts
.xcode-build/

# Bundler local install/config state
.bundle/
# Repo-local downloaded tool binaries/dependencies
.deps/

# Editor swap files (Vim-style)
*.swp
# Editor swap files (Vim-style)
*.swo
# Editor backup temp files
*~

# Per-user Xcode project UI/state
*.xcodeproj/xcuserdata/
# Per-user state in project workspace
*.xcodeproj/project.xcworkspace/xcuserdata/
# Per-user state for standalone workspaces
*.xcworkspace/xcuserdata/
# Xcode-generated SwiftPM workspace state
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
# Xcode test/build result bundles
*.xcresult
# Xcode test/build result bundles (directory form)
*.xcresult/

# Local environment variables/secrets
.env
# Environment variants/secrets
.env.*

# Developer-specific scratch/worktree area
.local/

# macOS Finder metadata file
.DS_Store
# LLVM raw coverage/profile output file
default.profraw
